# Obsidian Vault Root Directory (absolute path or relative to script)
VAULT_ROOT=./vault

# Model Provider configuration
# Choose one: anthropic, openai, gemini, openrouter, ollama
LLM_PROVIDER=anthropic

# Model name (e.g. claude-3-5-sonnet-latest, gpt-4o, gemini-1.5-flash, llama3)
LLM_MODEL=claude-3-5-sonnet-latest

# API Key for your chosen LLM provider (or leave blank if using Ollama locally)
LLM_API_KEY=your-api-key-here

# Optional: Custom API Endpoint URL (e.g. http://localhost:11434/v1 for local Ollama, or openrouter endpoint)
LLM_API_URL=

# Optional: Telegram Notifications & Calendar Approval Loop
# Telegram Bot Token (e.g. from BotFather)
TELEGRAM_BOT_TOKEN=
# Your personal Chat ID
TELEGRAM_CHAT_ID=

# Optional: Discord Webhook notifications (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Optional: Directory inside your vault for calendar/task items
TASKNOTES_FOLDER=TaskNotes
